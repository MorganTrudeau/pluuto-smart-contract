# Copy to .env and fill values
# Private key for deployer (0x...)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URLs (use Alchemy/Infura/your node)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org

# Etherscan (or equivalent) API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Contract configuration
CONTRACT_NAME=MyNFT
CONTRACT_SYMBOL=MNFT

# Platform fee configuration
# Fee percentage in basis points (250 = 2.5%, 500 = 5%, 1000 = 10%)
PLATFORM_FEE_PERCENTAGE=250
# Address that receives platform fees (REQUIRED)
PLATFORM_FEE_RECIPIENT=0xYOUR_FEE_RECIPIENT_ADDRESS

# For interact.ts script - deployed contract address
CONTRACT_ADDRESS=

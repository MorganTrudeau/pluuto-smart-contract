# Copy to .env.sepolia and .env.base and fill values
# Private key for deployer (hex, no 0x prefix)
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# RPC URL for the target network
RPC_URL=https://your-rpc-url-here

# Etherscan/BaseScan API key for contract verification
ETHERSCAN_API_KEY=your_api_key_here

# Contract configuration
CONTRACT_NAME=Pluuto Marketplace
CONTRACT_SYMBOL=PLU

# Platform fee configuration
# Fee percentage in basis points (250 = 2.5%, 500 = 5%, 1000 = 10%)
PLATFORM_FEE_PERCENTAGE=250
# Mint fee in wei (28000000000000000 = 0.028 ETH)
MINT_FEE=28000000000000000
# Address that receives platform fees (REQUIRED)
PLATFORM_FEE_RECIPIENT=0xYOUR_FEE_RECIPIENT_ADDRESS
# Platform address authorized to complete escrows (REQUIRED)
PLATFORM_ADDRESS=0xYOUR_PLATFORM_ADDRESS
